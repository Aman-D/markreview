{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://markreview.dev/schema/review.schema.json",
  "title": "MarkReview .review.json",
  "description": "Portable review artifact: a markdown doc, its revisions, and anchored comments. v0.1 (draft).",
  "type": "object",
  "required": ["version", "doc", "revisions", "comments"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "const": "0.1" },
    "doc": {
      "type": "object",
      "required": ["path", "rev"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "title": { "type": "string" },
        "rev": { "type": "integer", "minimum": 1 }
      }
    },
    "revisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rev"],
        "additionalProperties": false,
        "properties": {
          "rev": { "type": "integer", "minimum": 1 },
          "content": { "type": "string", "description": "Full markdown (rev 1) or omit if using diff." },
          "diffFrom": { "type": "integer", "minimum": 1 },
          "diff": { "type": "string", "description": "Unified diff from diffFrom, when content is omitted." },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "comments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "rev", "status", "thread"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["inline", "overall"] },
          "rev": { "type": "integer", "minimum": 1, "description": "Revision this comment was made against." },
          "anchor": {
            "type": "object",
            "description": "Text-quote selector. Required for inline comments.",
            "required": ["quote"],
            "additionalProperties": false,
            "properties": {
              "quote": { "type": "string" },
              "prefix": { "type": "string" },
              "suffix": { "type": "string" }
            }
          },
          "status": { "enum": ["open", "resolved", "wontfix", "orphaned"] },
          "thread": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["author", "role", "body"],
              "additionalProperties": false,
              "properties": {
                "author": { "type": "string" },
                "role": { "enum": ["human", "agent"] },
                "body": { "type": "string" },
                "action": { "enum": ["comment", "revised", "rejected", "asked"] },
                "appliedInRev": { "type": "integer", "minimum": 1 },
                "createdAt": { "type": "string", "format": "date-time" }
              }
            }
          }
        }
      }
    }
  }
}
